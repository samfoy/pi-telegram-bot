# Required
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_USER_ID=123456789

# LLM (defaults shown)
PROVIDER=anthropic
MODEL=claude-sonnet-4-5
THINKING_LEVEL=off

# Sessions (defaults shown)
MAX_SESSIONS=10
SESSION_IDLE_TIMEOUT=3600
SESSION_DIR=~/.pi/agent/sessions

# Streaming (defaults shown)
# Telegram rate limits message edits to ~1/second per message
STREAM_THROTTLE_MS=1000
TELEGRAM_MSG_LIMIT=4000

# Project discovery — comma-separated dirs to scan one level deep
WORKSPACE_DIRS=~/projects

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
